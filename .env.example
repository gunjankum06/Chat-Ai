# Environment variables
# ----------------------------
# LLM selection
# ----------------------------
LLM_PROVIDER=mock
# Allowed: mock | azure_openai | openai | anthropic | ollama

# ----------------------------
# LangSmith observability (optional)
# ----------------------------
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=Chat-Ai
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_REDACT=true   # redact PII/secrets from traces (default: true when tracing is on)

# ----------------------------
# Azure OpenAI settings (only if LLM_PROVIDER=azure_openai)
# ----------------------------
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=YOUR_KEY
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# Max tool loop steps (safety)
MAX_TOOL_STEPS=5

# ----------------------------
# Azure DevOps settings (only if using ado_tools_server)
# ----------------------------
ADO_ORG=your-ado-org
ADO_PROJECT=your-project
ADO_PAT=your-personal-access-token